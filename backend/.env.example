# ---- Required. The server refuses to boot without these. ----

# Atlas: Connect > Drivers. Remember to add the db name before the '?'.
# e.g. mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/quicknext?retryWrites=true&w=majority
MONGO_URI=

# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ---- Optional. Everything works without them. ----

PORT=5000
NODE_ENV=development
JWT_EXPIRES_IN=7d

# Comma-separated allowlist. Add the deployed frontend URL before demo day.
# e.g. http://localhost:5173,https://quicknext.vercel.app
CORS_ORIGINS=http://localhost:5173

# Leave blank to disable Google sign-in (demo accounts still log in).
GOOGLE_CLIENT_ID=

# Leave BOTH blank to run checkout on the simulated payment path.
# Fill both in to switch Razorpay on — no code change needed.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
